<Window x:Class="curs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:curs"
        mc:Ignorable="d"
        Title="Меню (Детский сад)" Height="650" Width="1000" ResizeMode="NoResize" Initialized="Window_Initialized">
    <TabControl>
        <TabItem Header="Меню" FontSize="20" Loaded="TabItem1_Loaded">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="8*"/>
                </Grid.RowDefinitions>
                <ToolBar Background="WhiteSmoke">
                    <Button Width="185" Click="FindUnusedDishes_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Блюда, которых&#x0a;нет в меню" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/find unused dishes in menu.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="CheckMenuCompleteness_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Незаполненные&#x0a;приемы пищи" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/search problems.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="GetvDMSByDateRange_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Фильтр по&#x0a;диапозону дат" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/filter time.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="SortvDMSByMealType_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Сортировка&#x0a;по дате" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/order-by.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="SaveWeeklyShoppingList_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Сохранить&#x0a;в таблицу" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/save.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator/>
                </ToolBar>
                <Separator VerticalAlignment="Bottom" BorderBrush="DarkGray"/>
                <Menu Grid.Row="1" Background="WhiteSmoke">
                    <MenuItem Click="EditAddM_Click" Height="50">
                        <MenuItem.Icon>
                            <Image Source="/Images/edit.ico" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                        <MenuItem.Header>
                            <TextBlock Text="Изменить&#x0a;запись" FontSize="16" TextWrapping="Wrap" TextAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator>
                        <Separator.Template>
                            <ControlTemplate TargetType="Separator">
                                <Rectangle Fill="DarkGray" Width="2" Margin="0,4"/>
                            </ControlTemplate>
                        </Separator.Template>
                    </Separator>
                    <MenuItem Click="EditAddM_Click" Height="50">
                        <MenuItem.Icon>
                            <Image Source="/Images/plus.ico" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                        <MenuItem.Header>
                            <TextBlock Text="Добавить&#x0a;запись" FontSize="16" TextWrapping="Wrap" TextAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator>
                        <Separator.Template>
                            <ControlTemplate TargetType="Separator">
                                <Rectangle Fill="DarkGray" Width="2" Margin="0,4"/>
                            </ControlTemplate>
                        </Separator.Template>
                    </Separator>
                    <MenuItem Click="DeleteM_Click" Height="50" IsChecked="True" Background="#FFFFF6F6">
                        <MenuItem.Icon>
                            <Image Source="/Images/delete.ico" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                        <MenuItem.Header>
                            <TextBlock Text="Удалить&#x0a;запись" FontSize="16" TextWrapping="Wrap" TextAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator>
                        <Separator.Template>
                            <ControlTemplate TargetType="Separator">
                                <Rectangle Fill="DarkGray" Width="2" Margin="0,4"/>
                            </ControlTemplate>
                        </Separator.Template>
                    </Separator>
                </Menu>
                <Separator VerticalAlignment="Bottom" BorderBrush="DarkGray"/>
                <ListView x:Name="listViewM" Grid.Row="2" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="130" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Дата}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Дата" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="290" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Завтрак}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Завтрак" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="290" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Обед}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Обед" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="290" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Полдник}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Полдник" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </TabItem>
        <TabItem Header="Блюда" FontSize="20" Loaded="TabItem2_Loaded">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="7*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <ToolBar Background="WhiteSmoke" Grid.ColumnSpan="2">
                    <Button Width="180" Click="CategoryPopularity_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Кол-во подач&#x0a;категорий" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/category popularity.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="190" Click="CategoryRotationCompliance_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Расчет&#x0a;интервалов&#x0a;между подачей" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/category rotation compliance.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="DishServingDates_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Даты подачи&#x0a;блюд" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/dishes serving dates.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="GetConsecutiveServingDays_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Сколько дней&#x0a;повторялись&#x0a;блюдо" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/get consecutive serving days.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="2"/>
                    <Button Width="185" Click="CountDishServings_Click">
                        <StackPanel Orientation="Horizontal" ToolTip="">
                            <TextBlock TextAlignment="Center" FontSize="16" Text="Сколько раз&#x0a;подавалось&#x0a;блюдо" TextWrapping="Wrap"/>
                            <Separator Opacity="0" Width="5"/>
                            <Image Source="/Images/count dish servings.ico"/>
                        </StackPanel>
                    </Button>
                    <Separator/>
                </ToolBar>
                <Separator VerticalAlignment="Bottom" Grid.ColumnSpan="2" BorderBrush="DarkGray"/>
                <ListView x:Name="listViewD" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="150" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DishName}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Название" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="100" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Category.CategoryName}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Категория" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="250" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Recipe}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Состав" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView x:Name="listViewRC" Grid.Row="1" Grid.Column="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="150" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Dish.DishName}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Блюдо" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="130" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Ingredient.ProductName}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Ингридиент" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="130" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Quantity}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="Кол-во" HorizontalAlignment="Left"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
