<Window x:Class="curs.wSelectTimeGap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:curs"
        mc:Ignorable="d"
        Title="wSelectTimeGap" Height="200" Width="300">
    <StackPanel Orientation="Vertical">
        <Label Content="Начало:" FontSize="18"/>
        <DatePicker x:Name="dpDateStart" Margin="20,0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Separator Width="300" Height="8"/>
        <Label Content="Конец:" FontSize="18"/>
        <DatePicker x:Name="dpDateEnd" Margin="20,0" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Separator Width="300" Height="8"/>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="btnForth" Width="120" IsDefault="True" Content="Дальше" FontSize="18" Click="Forth_Click" Margin="20,0,0,0"/>
            <Button x:Name="btnCansel" Width="120" IsCancel="True" Content="Отмена" FontSize="18" Click="Cansel_Click" Margin="20,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
