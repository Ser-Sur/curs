<Window x:Class="curs.wViewDishServingDate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:curs"
        mc:Ignorable="d"
        Title="Даты подач блюд" Height="400" Width="320" ResizeMode="NoResize" Loaded="Window_Loaded" Icon="/Images/find unused dishes in menu.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="6*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="tbFind" Margin="40,10,20,10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="14"/>
            <Button Grid.Column="1" Click="Find_Click" Margin="20,10,40,10">
                <StackPanel Orientation="Horizontal" ToolTip="">
                    <TextBlock TextAlignment="Center" FontSize="16" Text="Поиск" TextWrapping="Wrap"/>
                    <Separator Opacity="0" Width="5"/>
                    <Image Source="/Images/find unused dishes in menu.ico"/>
                </StackPanel>
            </Button>
        </Grid>
        <ListView x:Name="listView" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="180" >
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DishName}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumn.Header>
                            <TextBlock Text="Название блюда" HorizontalAlignment="Left"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="120" >
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MenuDate}" TextAlignment="Left" FontSize="14" Margin="5,0" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumn.Header>
                            <TextBlock Text="Даты" HorizontalAlignment="Left"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <Button Grid.Row="2" Content="Закрыть" FontSize="18" Margin="50,5" Click="Close_Click"/>
    </Grid>
</Window>
